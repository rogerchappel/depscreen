{
  "name": "depscreen",
  "version": "0.1.0",
  "description": "Local dependency review CLI for agent-built JavaScript projects.",
  "type": "module",
  "main": "./dist/src/index.js",
  "exports": {
    ".": "./dist/src/index.js"
  },
  "bin": {
    "depscreen": "./dist/src/cli.js"
  },
  "files": [
    "dist/src",
    "docs",
    "RELEASE_NOTES.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "pretest": "npm run build",
    "test": "node --test dist/tests/**/*.test.js",
    "smoke": "bash scripts/smoke.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke",
    "prepublishOnly": "npm run release:check"
  },
  "keywords": [
    "dependencies",
    "dependency-review",
    "supply-chain",
    "security",
    "cli",
    "package-json",
    "lockfile",
    "agents"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rogerchappel/depscreen.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/depscreen/issues"
  },
  "homepage": "https://github.com/rogerchappel/depscreen#readme",
  "engines": {
    "node": ">=18.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "typescript": "^5.8.3"
  }
}
